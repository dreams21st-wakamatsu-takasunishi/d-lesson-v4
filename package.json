{
  "name": "d-lesson-v4",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "check:legacy-password": "node scripts/check-legacy-password.mjs",
    "check:admin-auth-utils": "node scripts/check-admin-auth-utils.mjs",
    "check:admin-report-utils": "node scripts/check-admin-report-utils.mjs",
    "check:inline-handlers": "node scripts/check-inline-handlers.mjs",
    "check:undefined": "node scripts/check-js-undefined.mjs",
    "check:public-env": "node scripts/check-public-env.mjs",
    "check:public-test-env": "node scripts/check-public-env.mjs --allow-test-table",
    "check:public-url": "node scripts/check-public-url.mjs",
    "check:public-production-url": "node scripts/check-public-url.mjs --expect-table=user_data --production",
    "check:public-latest": "node scripts/check-public-url.mjs --expect-table=user_data --production --expect-current-git-sha --retries=6 --retry-delay-ms=10000",
    "check:release-test": "npm run check:public-test-env && npm run check:legacy-password && npm run check:admin-auth-utils && npm run check:admin-report-utils && npm run check:inline-handlers && npm run check:undefined && npm run build",
    "check:release": "npm run check:public-env && npm run check:legacy-password && npm run check:admin-auth-utils && npm run check:admin-report-utils && npm run check:inline-handlers && npm run check:undefined && npm run build",
    "check:converted-users": "node scripts/check-converted-users.mjs",
    "check:student-login-csv": "node scripts/check-student-login-csv.mjs",
    "convert:legacy-users": "node scripts/convert-legacy-users.mjs",
    "build:student-login-csv": "node scripts/build-student-login-csv.mjs",
    "build:student-login-cards": "node scripts/build-student-login-cards.mjs",
    "build:student-access-sql": "node scripts/build-student-access-sql.mjs",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.0"
  }
}
