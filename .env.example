# Copy to .env.local for local testing. Do not commit real project values.
VITE_SUPABASE_URL=

# Prefer a Supabase publishable key. Legacy anon keys also work for now.
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=

# Use test_user_data while the current legacy roster sync is still being refactored.
VITE_SUPABASE_TABLE=test_user_data
VITE_SUPABASE_USE_TEST_TABLE=true

# Legacy sync downloads the whole roster and should stay false on public URLs.
# Turn this on only for a trusted local classroom/test environment until Auth + RLS are complete.
VITE_ENABLE_LEGACY_SUPABASE_SYNC=false

# Set true on public URLs to require Supabase Auth before showing the app roster.
VITE_REQUIRE_SUPABASE_AUTH=false

# Legacy classroom password. Do not set this on public URLs because Vite bundles it into JS.
# VITE_LEGACY_ADMIN_PASS=change-this-local-only
