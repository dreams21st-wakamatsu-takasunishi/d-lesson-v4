# Copy to .env.local for local testing. Do not commit real project values.
VITE_SUPABASE_URL=https://lmonjfdxtefsvgtdixid.supabase.co

# Prefer a Supabase publishable key. Legacy anon keys also work for now.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_v3lobOmWyC0vzpCWkvqiyQ_LkGWzPGD
# VITE_SUPABASE_ANON_KEY=

# Use user_data for production. Use test_user_data only for isolated verification.
VITE_SUPABASE_TABLE=user_data
VITE_SUPABASE_USE_TEST_TABLE=false

# Deprecated legacy full-roster sync. The app keeps this disabled for Auth/RLS operation.
VITE_ENABLE_LEGACY_SUPABASE_SYNC=false

# RLS sync uses Supabase Auth + RLS to load only rows allowed for the logged-in account.
VITE_ENABLE_RLS_CLOUD_SYNC=true

# Optional: read/write __GLOBAL_SETTINGS__ from lesson_settings instead of the student table.
# Enable only after running supabase/sql/lesson_settings_table.sql.
VITE_ENABLE_SETTINGS_TABLE=true

# Set true on public URLs to require Supabase Auth before showing the app roster.
VITE_REQUIRE_SUPABASE_AUTH=true

# Optional: click-only student login.
# When VITE_STUDENT_LOGIN_EMAIL_DOMAIN is set, students log in by selecting a number
# and pressing the on-screen numeric keypad. The app builds the hidden email as:
# VITE_STUDENT_LOGIN_EMAIL_PREFIX + padded_number + "@" + VITE_STUDENT_LOGIN_EMAIL_DOMAIN
# Example: dlesson-student-001@example.com
# Optional campus URLs can add ?campus=wakamatsu, which builds:
# dlesson-student-wakamatsu-001@example.com
VITE_STUDENT_LOGIN_EMAIL_DOMAIN=dlesson.example.com
VITE_STUDENT_LOGIN_EMAIL_PREFIX=dlesson-student-
VITE_STUDENT_LOGIN_CAMPUS_CODE=
# Optional: comma-separated campus codes to try on classroom login when URL has no ?campus=.
VITE_STUDENT_LOGIN_CAMPUS_CODES=
# After all classroom Auth users are synced, restrict ?campus= URLs to that campus.
VITE_STUDENT_LOGIN_STRICT_CAMPUS=false
VITE_STUDENT_LOGIN_NUMBER_PAD=3
VITE_STUDENT_LOGIN_MIN=1
VITE_STUDENT_LOGIN_MAX=50
VITE_STUDENT_LOGIN_PASSCODE_MIN_LENGTH=6
VITE_STUDENT_LOGIN_PASSCODE_MAX_LENGTH=12

# Practice history retention.
# Keeps the latest N logs per student and drops logs older than the retention days.
# Set VITE_PRACTICE_LOG_RETENTION_DAYS=0 only when you intentionally want no date pruning.
VITE_PRACTICE_LOG_LIMIT=300
VITE_PRACTICE_LOG_RETENTION_DAYS=180

# Public release login options.
# The browser shows the registration form unless this is set to false.
# The Edge Function still requires PUBLIC_STUDENT_REGISTRATION_ENABLED=true
# in Supabase secrets before registrations are actually accepted.
VITE_ENABLE_PUBLIC_STUDENT_REGISTRATION=true
VITE_PUBLIC_STUDENT_REGISTRATION_FUNCTION=public-register-student
