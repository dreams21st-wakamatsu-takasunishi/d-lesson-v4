# Copy to .env.local for local testing. Do not commit real project values.
VITE_SUPABASE_URL=

# Prefer a Supabase publishable key. Legacy anon keys also work for now.
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=

# Use test_user_data while the current legacy roster sync is still being refactored.
VITE_SUPABASE_TABLE=test_user_data
VITE_SUPABASE_USE_TEST_TABLE=true

# Legacy sync downloads the whole roster and should stay false on public URLs.
# Turn this on only for a trusted local classroom/test environment until Auth + RLS are complete.
VITE_ENABLE_LEGACY_SUPABASE_SYNC=false

# RLS sync uses Supabase Auth + RLS to load only rows allowed for the logged-in account.
# Turn this on only after running and verifying the RLS SQL/access rows.
VITE_ENABLE_RLS_CLOUD_SYNC=false

# Optional: read/write __GLOBAL_SETTINGS__ from lesson_settings instead of the student table.
# Enable only after running supabase/sql/lesson_settings_table.sql.
VITE_ENABLE_SETTINGS_TABLE=false

# Set true on public URLs to require Supabase Auth before showing the app roster.
VITE_REQUIRE_SUPABASE_AUTH=false

# Optional: click-only student login.
# When VITE_STUDENT_LOGIN_EMAIL_DOMAIN is set, students log in by selecting a number
# and pressing the on-screen numeric keypad. The app builds the hidden email as:
# VITE_STUDENT_LOGIN_EMAIL_PREFIX + padded_number + "@" + VITE_STUDENT_LOGIN_EMAIL_DOMAIN
# Example: dlesson-student-001@example.com
VITE_STUDENT_LOGIN_EMAIL_DOMAIN=
VITE_STUDENT_LOGIN_EMAIL_PREFIX=dlesson-student-
VITE_STUDENT_LOGIN_NUMBER_PAD=3
VITE_STUDENT_LOGIN_MIN=1
VITE_STUDENT_LOGIN_MAX=40
VITE_STUDENT_LOGIN_PASSCODE_MIN_LENGTH=6
VITE_STUDENT_LOGIN_PASSCODE_MAX_LENGTH=12

# Legacy classroom password. Disabled in production builds and whenever VITE_REQUIRE_SUPABASE_AUTH=true.
# Use only for trusted local dev/classroom fallback.
VITE_ALLOW_LEGACY_ADMIN_PASS=false
# VITE_LEGACY_ADMIN_PASS=change-this-local-only

# Optional build metadata. GitHub Actions sets this automatically.
# VITE_BUILD_COMMIT=

# Before public test release, run:
# npm.cmd run check:public-test-env
#
# Before real user_data release, switch VITE_SUPABASE_TABLE=user_data,
# VITE_SUPABASE_USE_TEST_TABLE=false, then run:
# npm.cmd run check:public-env
